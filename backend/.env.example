# Server Configuration
PORT=3002
NODE_ENV=development

# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Optional: multiple keys — auto-rotates when one hits rate limit (create at console.groq.com)
# GROQ_API_KEYS=gsk_key_one,gsk_key_two,gsk_key_three

# Optional — defaults to llama-3.1-8b-instant (faster, higher rate limits)
GROQ_MODEL=llama-3.1-8b-instant

# CORS Configuration
CORS_ORIGIN=chrome-extension://*

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
